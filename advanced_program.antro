module: "advanced_program";

require: "time.module";
#require: "regex.module";

def: MAX 500; 

begin: (void)
     # testing this program
     
     var ty = call: factorUpBy2(MAX);
     call: print(ty);
     
     export: factorUpBy2, getString ;
end;

# composite[class]: Account(){
